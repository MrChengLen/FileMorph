# Normalize line endings for cross-platform compatibility
* text=auto

# Force LF for scripts and configs
*.py text eol=lf
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.txt text eol=lf

# Git hooks (extension-less, POSIX shell — must be LF on Linux runners and git-bash).
.githooks/* text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary

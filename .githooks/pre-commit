#!/bin/sh
# FileMorph pre-commit leak-blocker (CLAUDE.md "Pre-Commit Secret-Scan" + "Pre-Commit Scope-Check")
# Install: git config core.hooksPath .githooks

set -e

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
[ -z "$STAGED_FILES" ] && exit 0

FAIL=0

# Allow legitimate locations (Impressum, privacy, terms, COMMERCIAL-LICENSE, gdpr-design, self-hosting).
# locale/ catalogs are mechanically extracted from the impressum/privacy/terms templates above —
# they cannot avoid carrying the same address/email strings. Treating them as public is consistent
# with the source templates being public.
ALLOW_RE='^(app/templates/(impressum|privacy|terms)\.html|COMMERCIAL-LICENSE\.md|docs/gdpr-account-deletion-design\.md|docs/api-usage-guide\.md|docs/self-hosting\.md|docs/dpa-template\.md|docs/email-setup\.md|docs-internal/.*|\.githooks/.*|\.github/workflows/scope-guard\.yml|CHANGELOG\.md|locale/.*\.(po|pot|mo)|\.env\.example)$'

# Personal/operational identifiers that should never land in public code.
PATTERNS='lennart\.seidel@icloud\.com|lennart@filemorph\.io|Reetwerder|21029 Hamburg'

# Operations-strings that belong in the ops-repo, not in the public app-repo.
OPS_PATTERNS='/opt/filemorph(/|$|[[:space:]])|/var/log/filemorph|/home/deploy([[:space:]]|/)|Hetzner CX|HETZNER_HOST|HETZNER_SSH_USER|HETZNER_SSH_KEY|OPS_REPO_DISPATCH_PAT|GHCR_PAT|appleboy/ssh-action'

# Secret-value assignment patterns (catches paste of actual .env content).
SECRET_ASSIGN='(JWT_SECRET|SMTP_PASSWORD|STRIPE_SECRET_KEY|STRIPE_WEBHOOK_SECRET|DATABASE_URL|API_KEY|POSTGRES_PASSWORD|GHCR_PAT|OPS_REPO_DISPATCH_PAT|HETZNER_SSH_KEY)[[:space:]]*=[[:space:]]*[^[:space:]$]'

# Secret-value PATTERNS — catch leaked tokens by their format, regardless of variable name.
SECRET_VALUES='sk_live_[a-zA-Z0-9]{8}|rk_live_[a-zA-Z0-9]{8}|ghp_[a-zA-Z0-9]{16}|gho_[a-zA-Z0-9]{16}|github_pat_[a-zA-Z0-9_]{16}|AKIA[0-9A-Z]{16}|-----BEGIN [A-Z ]*PRIVATE KEY-----'

for f in $STAGED_FILES; do
  echo "$f" | grep -Eq "$ALLOW_RE" && continue
  ADDITIONS=$(git diff --cached -- "$f" | grep -E "^\+" | grep -Ev "^\+\+\+" || true)
  if echo "$ADDITIONS" | grep -Eq "$PATTERNS"; then
    echo "BLOCK: $f contains private identifier (personal email / home address). Move to docs-internal/ or redact." >&2
    FAIL=1
  fi
  if echo "$ADDITIONS" | grep -Eq "$OPS_PATTERNS"; then
    echo "BLOCK: $f contains an ops-content pattern (server path / Hetzner / deploy-secret variable). This belongs in MrChengLen/filemorph-ops, not the public repo." >&2
    FAIL=1
  fi
  if echo "$ADDITIONS" | grep -Eq "$SECRET_ASSIGN"; then
    echo "BLOCK: $f appears to contain a secret-value assignment (looks like .env content). Use docs-internal/ or .env (gitignored)." >&2
    FAIL=1
  fi
  if echo "$ADDITIONS" | grep -Eq "$SECRET_VALUES"; then
    echo "BLOCK: $f looks like it contains a leaked secret token (Stripe live / GitHub PAT / AWS key / SSH private key). Rotate the credential immediately and remove from staged content." >&2
    FAIL=1
  fi
done

# Block staging of files that should be in docs-internal/.
INTERNAL_PATHS='^docs/(admin-cockpit|open-tasks|filemorph-io-runbook|marketing-plan|seo-strategy|business-case|claims-audit|launch-gate-snapshot|launch-readiness-tracker|seo-audit|user-acquisition-strategy|requirements-v2|sprint-5-multi-file-plan)\.md$'

# Block staging of files that are ops-only and must never appear in the public repo.
FORBIDDEN_PATHS='^(compose\.prod\.yml|deploy\.sh|\.env\.production(\..*)?|CLAUDE\.md)$|^runbooks/|^docs-internal/'

for f in $STAGED_FILES; do
  if echo "$f" | grep -Eq "$INTERNAL_PATHS"; then
    echo "BLOCK: $f belongs in docs-internal/ (operations-internal, not for self-hosters)." >&2
    FAIL=1
  fi
  if echo "$f" | grep -Eq "$FORBIDDEN_PATHS"; then
    echo "BLOCK: $f is ops-only and must never land in the public repo. Move to MrChengLen/filemorph-ops instead." >&2
    FAIL=1
  fi
done

if [ "$FAIL" = "1" ]; then
  echo "" >&2
  echo "Bypass only if you are certain (NOT for force-push or main): git commit --no-verify" >&2
  exit 1
fi

# Tailwind dynamic-class gate — forbid `class="border-{{ x }}-500"` patterns
# that break JIT extraction at build time. Hard gate (blocks the commit). See
# scripts/check_template_classes.py docstring + app/templates/_components/README.md.
if echo "$STAGED_FILES" | grep -qE '^app/templates/.*\.html$'; then
  if command -v python >/dev/null 2>&1; then
    python scripts/check_template_classes.py || exit 1
  elif [ -x "Z:/Python/projects/fileforge/.venv/Scripts/python.exe" ]; then
    "Z:/Python/projects/fileforge/.venv/Scripts/python.exe" scripts/check_template_classes.py || exit 1
  fi
fi

# Soft advisory layer — App-repo vs Ops-repo scope-review on staged diff.
# Catches subtle drift the hard gate above doesn't (hardcoded SaaS URLs,
# Stripe-gated routes without guards, JSON-LD with hardcoded origins, ...).
# Informational only — never blocks. See scripts/scope_review.py docstring.
if command -v python >/dev/null 2>&1; then
  python scripts/scope_review.py || true
elif [ -x "Z:/Python/projects/fileforge/.venv/Scripts/python.exe" ]; then
  "Z:/Python/projects/fileforge/.venv/Scripts/python.exe" scripts/scope_review.py || true
fi
